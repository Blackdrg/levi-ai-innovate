# LEVI AI Sovereign OS v8 - Environment Configuration Template
# This file is used to configure the Unified Sovereign Monolith (levi-api).
# Copy this to .env (root) or .env.local

# ── CORE ──────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=             # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CLIENT_KEY=             # Client-side API key for simple sync auth
PORT=8000               # Main API Port

# ── FRONTEND & API GATEWAY ────────────────────
# These variables guide the React/Vite builds and internal routing
VITE_API_BASE_URL=http://localhost:8000/api
VITE_ENVIRONMENT=production
VITE_ENABLE_TRACING=true

# ── FIREBASE (Sovereign Shield) ───────────────
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_SERVICE_ACCOUNT=backend/config/serviceAccountKey.json

# ── AI MODELS (Cognitive Engine) ──────────────
# LEVI uses high-fidelity models for reasoning and synthesis
GROQ_API_KEY=
TOGETHER_API_KEY=

# ── STORAGE (Media & Reflection Vault) ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=levi-media
CLOUDFRONT_DOMAIN=

# ── PAYMENTS ──────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── EMAIL & PUSH NOTIFICATIONS ────────────────
RESEND_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=

# ── INFRASTRUCTURE (Postgres, Redis, Kafka) ───
# The backbone for the cognitive DAG and real-time streams
DATABASE_URL=postgresql://levi:levi_pass@postgres:5432/levidb
REDIS_URL=redis://redis:6379/0
KAFKA_URL=kafka:29092
DAILY_AI_LIMIT=500      # Soft limit for planetary AI spend tracking
METRICS_ENABLED=true    # Enable evaluation tracing
