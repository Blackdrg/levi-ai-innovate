# ─────────────────────────────────────────────
# LEVI AI — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# ── Database ────────────────────────────────
# Local:      sqlite:///./levi_v2.db  (auto used if not set)
# Production: Get from Render → Postgres → Internal Connection String
DATABASE_URL=postgresql://levi:levi@db:5432/levi

# ── Redis ───────────────────────────────────
# Local:      redis://localhost:6379
# Production: Get from Render → Redis → Internal URL
REDIS_URL=redis://redis:6379

# ── Security ────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-secure-random-key-here
POSTGRES_PASSWORD=levi

# ── CORS ────────────────────────────────────
# Set to your Vercel URL in production, or * for open
CORS_ORIGINS=*

# ── Together.AI (Image Generation) ──────────
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# ── Stripe (Payments) ───────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...        # Use sk_test_... for testing
STRIPE_PUBLISHABLE_KEY=pk_live_...   # Used in frontend

# Webhook secret — get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create products in Stripe Dashboard first, then paste IDs here
# Dashboard → Products → Add Product → Add Price → copy "Price ID" (starts with price_)
STRIPE_PRICE_PRO=price_REPLACE_WITH_PRO_MONTHLY_PRICE_ID
STRIPE_PRICE_CREATOR=price_REPLACE_WITH_CREATOR_MONTHLY_PRICE_ID
STRIPE_PRICE_CREDITS_SMALL=price_REPLACE_WITH_50_CREDITS_PRICE_ID
STRIPE_PRICE_CREDITS_MEDIUM=price_REPLACE_WITH_200_CREDITS_PRICE_ID

# ── AWS S3 (Video/Image Storage) ────────────
# Get from: AWS Console → IAM → Create User → Attach S3FullAccess policy
# Then: S3 → Create Bucket → copy bucket name
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=levi-media

# ── Email (Daily Quotes) ────────────────────
# Get from: https://resend.com → API Keys (free: 3000 emails/month)
RESEND_API_KEY=re_...

# ── App URLs ────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Render-specific ─────────────────────────
RENDER=true          # Disables heavy local AI models on Render free tier
PORT=10000
