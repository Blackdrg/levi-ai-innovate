# ── LEVI-AI Environment Configuration ─────────────────
# Copy this to .env and fill in the actual values.

# 1. Core Config
SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql://user:password@localhost:5432/levi_db
ADMIN_KEY=your-secure-admin-key
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
USE_CELERY=true
DAILY_AI_LIMIT=10  # Max daily AI interactions for free users

# 2. Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_AMOUNT=29900
RAZORPAY_CREATOR_PLAN_AMOUNT=59900

# 3. AI Services
GROQ_API_KEY=
TOGETHER_API_KEY=
HEYGEN_API_KEY=
LEONARDO_API_KEY=
SD_MODEL_ID=runwayml/stable-diffusion-v1-5  # Optional: stabilityai/stable-diffusion-xl-base-1.0

# 4. Auth (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 5. Storage (AWS S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDFRONT_DOMAIN=

# 6. Communication & Monitoring
# Generate with: npx web-push generate-vapid-keys
RESEND_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@yourdomain.com
FRONTEND_URL=http://localhost:8080
SENTRY_DSN=

# 7. Rendering / Hosting (Auto-set by platforms)
# RENDER=true
# DIGITALOCEAN=true
