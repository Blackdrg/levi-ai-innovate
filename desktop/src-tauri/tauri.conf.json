{
  "project_name": "LEVI-AI",
  "version": "1.0.0",
  "identifier": "com.levi.os",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LEVI Dashboard",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      },
      {
        "title": "LEVI Command Palette",
        "width": 700,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "label": "palette"
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "nsis"],
      "identifier": "com.levi.os",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "externalBin": [
        "binaries/levi-core"
      ]
    }
  },
  "bundle": {
    "externalBin": [
      "bin/levi-core"
    ]
  }
}
