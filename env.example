# ─────────────────────────────────────────────
# LEVI-AI — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# ── Database ────────────────────────────────
# Local:      sqlite:///./levi_v2.db  (auto used if not set)
# Production: Get from Render → Postgres → Internal Connection String
DATABASE_URL=postgresql://levi:levi@db:5432/levi

# ── Redis ───────────────────────────────────
# Local:      redis://localhost:6379
# Production: Get from Render → Redis → Internal URL
REDIS_URL=redis://redis:6379

# ── Security ────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-secure-random-key-here
POSTGRES_PASSWORD=levi

# ── CORS ────────────────────────────────────
# Set to your Vercel URL in production, or * for open
CORS_ORIGINS=*

# ── Together.AI (Image Generation) ──────────
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

USE_CELERY=false

# ── Web Push Notifications ────────────────────
# Generate using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REPLACE_WITH_PUBLIC_VAPID_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_PRIVATE_VAPID_KEY
VAPID_ADMIN_EMAIL=admin@your-domain.com

# ── AWS S3 (Video/Image Storage) ────────────
# Get from: AWS Console → IAM → Create User → Attach S3FullAccess policy
# Then: S3 → Create Bucket → copy bucket name
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=levi-media

# ── Email (Daily Quotes) ────────────────────
# Get from: https://resend.com → API Keys (free: 3000 emails/month)
RESEND_API_KEY=re_...

# ── App URLs ────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Render-specific ─────────────────────────
RENDER=true          # Disables heavy local AI models on Render free tier
PORT=10000
