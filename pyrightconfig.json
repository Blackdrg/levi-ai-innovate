{
    "include": [
        "backend",
        "frontend"
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        ".venv"
    ],
    "venv": ".venv",
    "venvPath": ".",
    "extraPaths": [
        "."
    ],
    "typeCheckingMode": "basic",
    "reportMissingImports": false,
    "pythonVersion": "3.12"
}
