# LEVI-AI backend environment template
# Copy this file to `backend/.env` for local development or deployment bootstrapping.
# Replace every `replace_*` placeholder before production use.

# ── CORE ──────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8080
WORKERS=1
SKIP_MIGRATIONS=false
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30

# API and auth
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=replace_with_a_real_jwt_secret
SECRET_KEY=replace_with_a_real_app_secret
INTERNAL_SERVICE_KEY=replace_with_a_real_internal_service_key
ADMIN_KEY=replace_with_a_real_admin_key
AUDIT_CHAIN_SECRET=replace_with_a_real_audit_chain_secret
ENCRYPTION_KEY=replace_with_a_real_encryption_key
SOVEREIGN_MASTER_KEY=replace_with_a_real_64_char_hex_key
DCN_SECRET=replace_with_a_real_dcn_secret
CLIENT_KEY=replace_with_a_real_client_key

# ── FRONTEND & API GATEWAY ────────────────────
# These variables guide the React/Vite builds and internal routing
VITE_API_BASE_URL=http://localhost:8000/api
VITE_ENVIRONMENT=development
VITE_ENABLE_TRACING=true

# ── FIREBASE (Sovereign Shield) ───────────────
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_SERVICE_ACCOUNT=backend/config/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CREDENTIALS_PATH=firebase-adminsdk.json
GOOGLE_CLOUD_PROJECT=
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_STORAGE_BUCKET=

# ── AI MODELS (Cognitive Engine) ──────────────
# LEVI uses high-fidelity models for reasoning and synthesis
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_KEY=
TOGETHER_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
REPLICATE_API_TOKEN=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL_FAST=phi3:mini
OLLAMA_MODEL_GENERAL=llama3.1:8b
OLLAMA_MODEL_COMPLEX=llama3.3:70b
OLLAMA_MODEL_EMBED=nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text
MODEL_TIER_L1=llama3.1:8b
MODEL_TIER_L2=llama3.1:8b
MODEL_TIER_L3=llama3.1:70b
MODEL_TIER_L4=llama3.1:70b
MODEL_CANDIDATE=llama3-fine-tuned:latest
LOCAL_INFERENCE_PROVIDER=ollama
CLOUD_INFERENCE_PROVIDER=groq
LOCAL_MODEL_PATH=models/llama-3.gguf
SMALL_MODEL_PATH=backend/data/models/phi-3-mini.Q4_K_M.gguf
LOCAL_LLM_THREADS=4
MAX_LOCAL_CONCURRENCY=2
SHADOW_DEPLOYMENT_ACTIVE=false
SHADOW_TRAFFIC_PERCENT=10.0
DEPLOYMENT_STRATEGY=blue
TRAFFIC_SPLIT_GREEN=0
COMFYUI_URL=http://comfyui:8188
SDWEBUI_URL=http://sdwebui:7860
ANIMATEDIFF_URL=http://sdwebui:7860/animatediff

# ── STORAGE (Media & Reflection Vault) ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDFRONT_DOMAIN=
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=storage
BACKUP_DIR=vault/backups
BACKUP_PATH=backend/data/backups
ARCHIVE_PATH=./data/archive/cold_storage
ARCHIVE_KEY=replace_with_a_real_archive_key
HF_HOME=/app/data/huggingface
PIP_CACHE_DIR=/app/data/pip_cache
NPM_CONFIG_CACHE=/app/data/npm_cache
OLLAMA_MODELS=/root/.ollama/models

# ── PAYMENTS ──────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── EMAIL & PUSH NOTIFICATIONS ────────────────
RESEND_API_KEY=
RESEND_SENDER=onboarding@resend.dev
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SENDER_EMAIL=oracle@levi-ai.create.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@levi-ai.create.app
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
FCM_SERVER_KEY=

# ── INFRASTRUCTURE (Postgres, Redis, Kafka) ───
# The backbone for the cognitive DAG and real-time streams
DATABASE_URL=postgresql+asyncpg://levi:replace_me@postgres:5432/levi_db
POSTGRES_URL=postgresql+asyncpg://levi:replace_me@postgres:5432/levi_db
REDIS_URL=redis://redis:6379/0
REDIS_MODE=standalone
REDIS_SENTINEL_SERVICE=mymaster
REDIS_SENTINEL_NODES=redis-sentinel-1:26379,redis-sentinel-2:26379
KAFKA_URL=kafka:29092
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_me
VECTOR_DB_PATH=backend/data/vector_db
MONGODB_URI=
MONGODB_DB_NAME=levi_ai
OTEL_SERVICE_NAME=levi-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLING_RATE=1.0
METRICS_ENABLED=true
INSTANCE_ID=local-api
CELERY_WORKER_NAME=worker-default
ALERT_WEBHOOK_URL=
CU_ABORT_THRESHOLD=500
MAX_CONCURRENT_TASKS=4
MAX_PARALLEL_WAVES=2
DAILY_AI_LIMIT=500
API_TIMEOUT=20
RETRY_ATTEMPTS=3
HEURISTIC_VRAM_MB=8192
ENABLE_LOCAL_DOCKER_SCALING=false
VRAM_SAFETY_BUFFER_PERCENT=0.15
USE_CELERY=true
CELERY_CONCURRENCY=4
WORKER_CONCURRENCY=4
DISTRIBUTED_MODE=false
DCN_NODE_ID=node-alpha
NODE_ROLE=coordinator
NODE_WEIGHT=1
DCN_PEERING_NODES=
SD_ENABLED=false
SWARM_SYNC_KEY=replace_with_a_real_swarm_sync_key
SWARM_ID=local_monolith
BRAIN_SERVICE_URL=http://brain-service:8000
MEMORY_SERVICE_URL=http://memory-service:8000
BRAIN_SERVICE_TOKEN=replace_with_a_real_brain_service_token
LEARNING_LOOP_ACTIVE=true
LEARNING_METRICS_ENABLED=true
TRAINING_TRIGGER_COUNT=500
EVOLUTION_FT_THRESHOLD=20
LEVI_WORKFLOW_MAX_ITERATIONS=5
AGE_PUBLIC_KEY=
RCLONE_REMOTE=
RCLONE_CONFIG_PATH=
TEST_MODE=false
ENABLE_CHAOS=false
RUN_LIVE_OLLAMA_TESTS=0
LEVI_TEST_TOKEN=sovereign_test_token_v14
OFFLINE_MODE=false
CHAOS_REDIS_OUTAGE=false
CHAOS_GPU_OVERLOAD=false
CHAOS_AGENT_TIMEOUT=
CHAOS_TOOL_CRASH=
