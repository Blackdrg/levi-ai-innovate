# ── LEVI-AI Sovereign OS v8 Environment Configuration ──
# Transform LEVI into a production-grade autonomous agent ecosystem.

# Security & Identity
SECRET_KEY=generate-a-long-random-string-here
ADMIN_KEY=your-admin-key-for-probes
INTERNAL_SERVICE_KEY=your-internal-service-key

# AI Model Keys (Cognitive Engine)
GROQ_API_KEY=gsk_xxx
TOGETHER_API_KEY=xxx
TAVILY_API_KEY=tvly-xxx

# Infrastructure (Postgres, Redis, Kafka)
DATABASE_URL=postgresql://levi:levi_pass@postgres:5432/levidb
REDIS_URL=redis://localhost:6379/0
KAFKA_URL=localhost:9092

# Firebase (Sovereign Shield)
FIREBASE_PROJECT_ID=levi-ai-c23c6
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# Operational
ENVIRONMENT=production
CELERY_CONCURRENCY=4
DAILY_AI_LIMIT=500

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api
VITE_ENABLE_TRACING=true
