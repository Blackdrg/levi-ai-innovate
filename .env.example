# 🪐 LEVI-AI: Sovereign OS v13.1.0-Hardened-PROD
# Environment Configuration Template (Production)
# 🛡️ 🚀 Engineered for Absolute Local Autonomy

# --- 1.0 CORE SYSTEM VERSIONING ---
# Identifies the graduation tier for audit and telemetry pulse headers.
SOVEREIGN_VERSION=v13.1.0-Hardened-PROD
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- 1.1 DATA RESIDENCY (SOVEREIGN GRADUATION) ---
# Enforces drive D residency for all persistent caches and weights.
HF_HOME=D:/LEVI-AI/data/huggingface
PIP_CACHE_DIR=D:/LEVI-AI/data/pip_cache
NPM_CONFIG_CACHE=D:/LEVI-AI/data/npm_cache
OLLAMA_MODELS=D:/LEVI-AI/data/ollama/models

# --- 2.0 SECURITY & CRYPTOGRAPHY (MANDATORY) ---
# Master encryption key for the Sovereign KMS (AES-256 GCM).
# Generate with: openssl rand -hex 32
SOVEREIGN_MASTER_KEY=your_64_char_hex_master_key_here

# Secret for signing the immutable audit ledger (HMAC-SHA256).
# Warning: Do not lose this key; audit integrity depends on it.
AUDIT_CHAIN_SECRET=your_audit_secret_link_here

# Secret for the Distributed Cognitive Network (DCN) gossip protocol.
# Min 32 chars recommended for high-fidelity pulse verification.
DCN_SECRET=your_distribution_secret_here

# Central JWT secret for session-bound mission authentication.
SECRET_KEY=sovereign_monolith_genesis_vault_key

# Cross-Origin Resource Sharing (CORS) allowlist.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- 3.0 DATA PERSISTENCE & FABRIC ---
# Postgres (Episodic Ledger): Async session management with partitions.
# Template: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/levi_ai

# Redis (Working Memory / Telemetry Pulse): TLS (rediss://) mandatory for PROD multi-node.
REDIS_URL=redis://localhost:6379/0

# Neo4j (Relational Knowledge Graph): Bolt protocol with SSL enforcement.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- 4.0 COGNITIVE INFERENCE & EMBEDDINGS ---
# Local Ollama Engine: The primary inference stack.
OLLAMA_BASE_URL=http://localhost:11434

# Hierarchical Model Routing (v13.1 Calibration)
MODEL_LOCAL=llama3.1:8b            # Standard mission reasoning
MODEL_COMPLEX=llama3.3:70b        # High-parameter reflection agent
MODEL_EMBED=nomic-embed-text      # Local-first 768d RAG embeddings

# Performance Gates & Safety Semaphores
# Safety First: 4 slots prevents CUDA OOM on standard 24GB hardware.
MAX_CONCURRENT_TASKS=4
CU_ABORT_THRESHOLD=500            # Automatic abort beyond 500 Cognitive Units

# --- 5.0 DISTRIBUTED COGNITIVE NETWORK (DCN) ---
# Multi-node swarm orchestration for multi-physical node deployments.
DCN_NODE_ID=node_prime
DCN_ROLE=coordinator              # Options: coordinator, worker
DCN_WEIGHT=1.0                    # Weighted task stealing distribution
DCN_PEERING_NODES=node_worker_1,node_worker_2

# v2.1 Scalability & Hardware Safety
VRAM_SAFETY_BUFFER_PERCENT=0.15   # Reserve 15% VRAM for OS/Stability
ENABLE_LOCAL_DOCKER_SCALING=false # Set to true for automated docker-compose scaling (TESTING ONLY)
SD_ENABLED=true                   # Enable Distributed Studio generation for this worker node

# v2.2 High-Availability Fabric (Redis HA)
REDIS_MODE=standalone             # Options: standalone, sentinel, cluster
REDIS_SENTINEL_SERVICE=mymaster   # Default master service name
REDIS_SENTINEL_NODES=localhost:26379,localhost:26380 # Sentinel peering list

# --- 6.0 AUTONOMOUS EVOLUTION & LEARNING ---
# LearningLoop: Pattern crystallization from high-fidelity missions.
LEARNING_LOOP_ACTIVE=true
TRAINING_TRIGGER_COUNT=500        # Missions (Score > 0.85) required for LoRA update
LEARNING_METRICS_ENABLED=true

# --- 7.0 DISASTER RECOVERY & OFF-SITE SYNC ---
# RTO (Recovery Time Objective): 300s verified by 'restore_drill.py'.
BACKUP_DIR=d:/LEVI-AI/vault/backups
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=d:/LEVI-AI/storage

# Off-site Synchronization (rclone + age encryption)
# Requires 'age' binary and configured rclone remote.
AGE_PUBLIC_KEY=your_age_public_key_here
RCLONE_REMOTE=cloud_vault_encrypted
RCLONE_CONFIG_PATH=/config/rclone/rclone.conf

# --- 8.0 CLOUD FALLBACK (OPTIONAL / MANAGED) ---
# WARNING: Enabling cloud fallback breaks absolute local residency.
# Use ONLY as an elastic buffer for L3/L4 missions during local saturation.
CLOUD_FALLBACK_ENABLED=false
GROQ_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
