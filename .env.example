# ── LEVI-AI Environment Configuration ─────────────────
# Copy this file to .env and fill in the actual values.
# IMPORTANT: Never commit your .env file.
#
# ─────────────────────────────────────────────────────────────────────────────
# CRITICAL FOR LOCAL REDIS-BACKED TESTING AND PRODUCTION:
#
#   ENVIRONMENT=production
#
# If ENVIRONMENT is not set (or set to "development"), Celery will run in
# task_always_eager=True mode — tasks execute INLINE, synchronously, and the
# Beat scheduler does nothing useful. Set ENVIRONMENT=production whenever you
# want real async Celery queuing (even on localhost with a local Redis).
# ─────────────────────────────────────────────────────────────────────────────

# 1. Core Config
SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=your-secure-admin-key
REDIS_URL=redis://localhost:6379/0

# Set to "production" for real Redis-backed Celery queuing and async tasks.
# Set to "development" for synchronous inline task execution (useful for simple tests).
ENVIRONMENT=production

USE_CELERY=true
DAILY_AI_LIMIT=500  # Max daily AI cost units (global, not per-user)
API_TIMEOUT=20       # External API call timeout in seconds

# 2. Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_AMOUNT=29900
RAZORPAY_CREATOR_PLAN_AMOUNT=59900

# 3. AI Services
GROQ_API_KEY=        # Required — primary LLM provider (streaming supported)
TOGETHER_API_KEY=    # Optional — Council of Models (Pro/Creator tier only)
HEYGEN_API_KEY=      # Optional — Video synthesis
LEONARDO_API_KEY=    # Optional — Image generation alt
SD_MODEL_ID=runwayml/stable-diffusion-v1-5

# 4. Firebase Auth (required for all authenticated routes)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=  # Path to .json file OR raw JSON string

# 5. Auth (Google OAuth — optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 6. Storage (AWS S3 — optional for gallery/media)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDFRONT_DOMAIN=

# 7. Communication & Monitoring
RESEND_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@yourdomain.com
FRONTEND_URL=http://localhost:8080
SENTRY_DSN=         # Optional — Sentry error tracking (production recommended)

# 8. Proactive Monitoring Alerts
# Discord/Slack webhook URL — Circuit Breaker will POST here when it opens.
# Leave blank to disable.
ALERT_WEBHOOK_URL=   # e.g. https://discord.com/api/webhooks/...

# 9. Rendering / Hosting (Auto-set by platforms — do not set manually)
# RENDER=true
# DIGITALOCEAN=true
# GOOGLE_CLOUD_PROJECT=your-project-id

# ── INSTANCE CONFIG (optional, for multi-instance visibility) ──
INSTANCE_ID=local-dev-1
