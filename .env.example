# 🪐 LEVI-AI: Sovereign OS v14.1.0-Autonomous-SOVEREIGN
# Environment Configuration Template (Graduation Ready)
# 🛡️ 🚀 Engineered for Absolute Local Autonomy and Distributed Resilience

# --- 1.0 CORE SYSTEM VERSIONING ---
SOVEREIGN_VERSION=v14.1.0-Autonomous-SOVEREIGN
STABILITY_BASELINE_TAG=v14.1.0-STABLE-BASELINE
ENVIRONMENT=development # production | development
LOG_LEVEL=INFO
PORT=8080
HOST=0.0.0.0
WORKERS=1
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30

# --- 2.0 DATA PERSISTENCE AND FABRIC ---
# Postgres (Identity and Missions)
DATABASE_URL=postgresql+asyncpg://levi:replace_me@localhost:5432/levi_db
# Redis (Consensus, Cache, and Billing)
REDIS_URL=redis://localhost:6379/0
# Kafka (Cognitive Event Bus - Optional)
KAFKA_URL=localhost:29092
# Neo4j (Memory Resonance Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_me
# Vector Storage
VECTOR_DB_PATH=backend/data/vector_db

# --- 3.0 SECURITY AND CRYPTOGRAPHY ---
# RS256: Place .pem keys in /certs directory for production
JWT_SECRET=replace_with_a_real_jwt_secret # HS256 Fallback only
INTERNAL_SERVICE_KEY=replace_with_a_real_internal_service_key
DCN_SECRET=replace_with_a_real_32_char_dcn_secret
ENCRYPTION_KEY=replace_with_a_real_encryption_key

# --- 3.1 SECURE SANDBOXING ---
SANDBOX_RUNTIME=
SANDBOX_SECCOMP_PROFILE=

# --- 3.2 KMS AND VAULT (Cognitive Security) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_TRANSIT_MOUNT=transit
SYSTEM_SECRET=levi-default-0000
KMS_PROVIDER=local # local | vault

# --- 4.0 DISTRIBUTED COGNITIVE NETWORK (DCN) ---
DCN_NODE_ID=node-alpha
NODE_ROLE=coordinator # coordinator | worker
NODE_WEIGHT=1
# Lease TTL in seconds for coordination sticky leadership
DCN_LEASE_TTL=30

# --- 5.0 COGNITIVE INFERENCE (Local & Cloud) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Cloud Fallback (Disabled by default in SECURE mode)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
CLOUD_FALLBACK_ENABLED=false
MAX_CONTEXT_TOKENS=32768

# --- 6.0 AGENT TOOLS AND EXTERNAL SERVICES ---
TAVILY_API_KEY=
SERPAPI_KEY=
GITHUB_TOKEN=
GOOGLE_CLOUD_PROJECT=
GCP_JSON_CREDENTIALS=backend/config/gcp_creds.json

# --- 7.0 PERFORMANCE AND BILLING ---
API_TIMEOUT=30
RETRY_ATTEMPTS=3
MAX_PARALLEL_WAVES=4
# Consumption Thresholds
DAILY_CU_LIMIT=1000
# Resource Pressure Monitoring
VRAM_MONITOR_ENABLED=true
HEURISTIC_VRAM_MB=8192
VRAM_SAFETY_BUFFER_PERCENT=0.15

# --- 8.0 OBSERVABILITY AND HYGIENE ---
METRICS_ENABLED=true
ALERT_WEBHOOK_URL=
# Memory Distillation Frequency (Cycles)
TRAINING_TRIGGER_COUNT=15
# Absolute Wipe (GDPR) - set to true for forced hardening
ENFORCE_HARD_PURGE=false

# --- 9.0 WORKER AND TASK ORCHESTRATION ---
USE_CELERY=true
CELERY_CONCURRENCY=4
CELERY_WORKER_NAME=worker-default

# --- 10.0 TELEMETRY AND TRACING ---
OTEL_SERVICE_NAME=levi-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLING_RATE=1.0
