# 🧠 LEVI-AI Sovereign Monolith v8.11.1 - Configuration Template

# ── 1. COGNITIVE SECRETS (EXTERNAL INFERENCE) ──
GROQ_API_KEY=gsk_...
TAVILY_API_KEY=tvly-...
OPENAI_API_KEY=sk-...
TOGETHER_API_KEY=...
ANTHROPIC_API_KEY=...

# ── 2. SOVEREIGN SERVICE FABRIC (DATABASES) ──
# Postgres (Identity - Tier 4)
DATABASE_URL=postgresql+asyncpg://admin:levi_pass_db@localhost:5432/sovereign

# Redis (Working Memory - Tier 1)
REDIS_URL=redis://localhost:6379/0

# Kafka (Telemetry Pulse)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=levi_pass_graph

# FAISS (Semantic - Tier 3)
FAISS_MEMORY_PATH=./backend/db/vector_indices

# Firestore (Episodic - Tier 2)
FIREBASE_PROJECT_ID=...
GOOGLE_APPLICATION_CREDENTIALS=./configs/firebase_key.json

# ── 3. SECURITY & VAULT (SOVEREIGN SHIELD) ──
# SovereignVault Encryption Key (AES-256)
SOVEREIGN_VAULT_KEY=...

# ── 4. MISSION INFRASTRUCTURE ──
PORT=8000
ENVIRONMENT=development # development, staging, production
LOG_LEVEL=INFO

# ── 5. MEDIA & TOOLS ──
FFMPEG_PATH=/usr/bin/ffmpeg
PYTHON_REPL_TIMEOUT=30

# ── 6. TELEMETRY ──
X_SOVEREIGN_ID=levi-monolith-01
KAFKA_RETENTION_HOURS=24
RESISTANCE_THRESHOLD=0.85
DREAMING_THRESHOLD=5
RESONANCE_DECAY_DAYS=90

# ── 7. FRONTEND CONFIG ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SSE_URL=http://localhost:8000/api/v8/telemetry/stream
