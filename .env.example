# 🧠 LEVI-AI Sovereign Monolith v13.0.0 - Configuration Template

# ── 1. COGNITIVE SECRETS (EXTERNAL INFERENCE) ──
GROQ_API_KEY=gsk_...
TAVILY_API_KEY=tvly-...
OPENAI_API_KEY=sk-...
TOGETHER_API_KEY=...
ANTHROPIC_API_KEY=...

# ── 2. SOVEREIGN SERVICE FABRIC (DATABASES) ──
# HNSW Vault (Semantic - Tier 3)
VAULT_PATH=./backend/db/vector_indices

# Postgres SQL Fabric (Identity & Episodic)
DATABASE_URL=postgresql+asyncpg://admin:levi_pass_db@localhost:5432/sovereign

# Redis Pulse Bus (Tier 1)
