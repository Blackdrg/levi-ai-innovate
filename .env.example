# 🪐 LEVI-AI: Sovereign OS v22.1 - REALITY BASELINE
# Environment Configuration Template
# 🛡️ 🚀 Engineered for hardware-bound truth. No fiction.

# --- 1.0 CORE SYSTEM ---
ENVIRONMENT=development # production | development
LOG_LEVEL=INFO
PORT=8080
HOST=0.0.0.0
ALLOW_HOTPATCH=0 # Set to 1 only in QEMU/Test environments for 0x99 SYSCALL

# --- 2.0 DATA PERSISTENCE (Tiered Memory) ---
# T1: High-Speed Nervous System (Redis)
REDIS_URL=redis://localhost:6379/0
# T2: Episodic Vault (Postgres)
DATABASE_URL=postgresql+asyncpg://levi:replace_me@localhost:5432/levi_db
# T3: Semantic Archive (FAISS)
VECTOR_DB_PATH=backend/data/vector_db
# T4: Relationship Topology (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_me

# --- 3.0 SECURITY & CONSENSUS ---
JWT_SECRET=replace_with_32_char_secret
DCN_SECRET=replace_with_32_char_secret
ENCRYPTION_KEY=replace_with_32_char_key
# 4-node Raft Quorum Check (3/4 required)
DCN_NODE_ID=node-01
DCN_LEASE_TTL=30

# --- 4.0 COGNITIVE INFERENCE ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b # 3B/7B/8B recommended for local VRAM cap
MAX_CONTEXT_TOKENS=32768

# --- 5.0 HARDWARE GATING ---
# Capping agents to 2-4 based on available VRAM
VRAM_MONITOR_ENABLED=true
HEURISTIC_VRAM_MB=8192 # Adjust based on your GPU
VRAM_SAFETY_BUFFER_PERCENT=0.15

# --- 6.0 TASK ORCHESTRATION ---
USE_CELERY=true
CELERY_CONCURRENCY=2 # Capped for stability
CELERY_WORKER_NAME=worker-alpha

# --- 7.0 EXTERNAL API FALLBACKS (Optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=
