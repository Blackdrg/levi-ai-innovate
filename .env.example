# LEVI-AI: Local-First Distributed AI Stack (v1.0.0-RC1)
# Environment Configuration Template

# --- CORE INFRASTRUCTURE ---
LEVI_DATA_DIR=d:/LEVI-AI/data
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- DATABASE LAYER ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/levi_ai
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- INFERENCE & EMBEDDINGS ---
OLLAMA_BASE_URL=http://localhost:11434
MODEL_LOCAL=llama3.1:8b
MODEL_EMBED=nomic-embed-text

# --- CLOUD FALLBACK (MANAGED) ---
# WARNING: Enabling cloud fallback sends mission data to third-party servers (Groq/OpenAI).
# This is DISABLED by default to maintain absolute local sovereignty.
CLOUD_FALLBACK_ENABLED=false
GROQ_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# --- SECURITY & DCN ---
INTERNAL_SERVICE_KEY=your_32_byte_hex_here
DCN_SECRET=your_32_byte_hex_here
DCN_NODE_ID=node_alpha

# --- STORAGE ---
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=d:/LEVI-AI/storage
